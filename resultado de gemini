3. Implementación del Código (Funcional)
Aquí tienes el núcleo del CRUD bajo la metodología solicitada.

A. Modelo de Datos (lib/domain/pelicula_model.dart)
Dart
class Pelicula {
  String id;
  String nombre;
  String genero;
  int duracion;

  Pelicula({required this.id, required this.nombre, required this.genero, required this.duracion});

  Map<String, dynamic> toMap() => {
    "nombre": nombre,
    "genero": genero,
    "duracion": duracion,
  };

  factory Pelicula.fromSnapshot(String id, Map<String, dynamic> data) {
    return Pelicula(
      id: id,
      nombre: data['nombre'] ?? '',
      genero: data['genero'] ?? '',
      duracion: data['duracion'] ?? 0,
    );
  }
}
B. Servicio CRUD (lib/data/firestore_service.dart)
Dart
import 'cloud_firestore/cloud_firestore.dart';
import '../domain/pelicula_model.dart';

class FirestoreService {
  final CollectionReference coll = FirebaseFirestore.instance.collection('peliculas');

  // CREATE
  Future<void> addPelicula(Pelicula p) => coll.add(p.toMap());

  // READ (Stream para cambios en tiempo real)
  Stream<List<Pelicula>> getPeliculas() {
    return coll.snapshots().map((snap) =>
        snap.docs.map((doc) => Pelicula.fromSnapshot(doc.id, doc.data() as Map<String, dynamic>)).toList());
  }

  // UPDATE
  Future<void> updatePelicula(Pelicula p) => coll.doc(p.id).update(p.toMap());

  // DELETE
  Future<void> deletePelicula(String id) => coll.doc(id).delete();
}
